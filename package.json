{
  "name": "search-agentcore-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "eslint . --ext .ts --no-error-on-unmatched-pattern",
    "typecheck": "tsc -b && pnpm --filter admin-console typecheck",
    "test": "pnpm -r test",
    "test:watch": "vitest",
    "build": "pnpm -r build",
    "synth": "pnpm --filter infra synth",
    "deploy": "pnpm --filter infra deploy"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
