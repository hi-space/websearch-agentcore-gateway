# AWS Configuration
NEXT_PUBLIC_REGION=ap-northeast-2
NEXT_PUBLIC_GATEWAY_ID=
NEXT_PUBLIC_GATEWAY_URL=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Optional: for local testing
# NEXT_PUBLIC_API_URL=http://localhost:3000

# LLM judge (AgentCore Evaluation) — 선택적 배포. 1일 때만 playground에 "AI 품질 평가" 버튼 노출.
NEXT_PUBLIC_JUDGE_ENABLED=0
# 사용할 evaluator id (기본 Builtin.Helpfulness). custom evaluator는 그 id로 교체.
JUDGE_EVALUATOR_ID=Builtin.Helpfulness
