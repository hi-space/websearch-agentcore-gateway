{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "outDir": "./.next",
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "types": ["@testing-library/jest-dom", "node"],
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "middleware.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
